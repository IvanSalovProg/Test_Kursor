<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PayApp.MainWindow"
        Width="900" Height="600"
        Title="Pay Processor">
	<Grid RowDefinitions="Auto,*,Auto" Margin="12">
		<!-- Панель управления -->
		<StackPanel Orientation="Horizontal" Spacing="8" Grid.Row="0">
			<Button Content="Run Pipeline" Click="OnRunPipelineClick"/>
			<TextBlock Text="Source XML:" VerticalAlignment="Center"/>
			<TextBox Width="320" Text="{Binding SourcePath, Mode=TwoWay}"/>
			<Button Content="..." Click="OnBrowseSourceClick"/>
		</StackPanel>

		<!-- Сотрудники -->
		<StackPanel Grid.Row="1" Margin="0,12,0,0">
			<TextBlock Text="Employees:" FontSize="16" FontWeight="Bold"/>
		<ItemsControl ItemsSource="{Binding Employees}">
			<ItemsControl.ItemTemplate>
				<DataTemplate>
					<StackPanel Orientation="Horizontal" Spacing="6">
						<TextBlock Text="{Binding Name}" FontWeight="Bold" />
						<TextBlock Text="{Binding Surname}" FontWeight="Bold"/>
						<TextBlock Text=":"/>
						<TextBlock Text="{Binding TotalSalary}"/>
					</StackPanel>
				</DataTemplate>
			</ItemsControl.ItemTemplate>
		  </ItemsControl>
		</StackPanel>

		<!-- Месячные итоги -->
		<StackPanel Grid.Row="2" Margin="0,12,0,0">
			<TextBlock Text="Monthly Totals:" FontSize="16" FontWeight="Bold"/>
			<ItemsControl ItemsSource="{Binding MonthlyTotals}">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<StackPanel Orientation="Horizontal" Spacing="6">
							<TextBlock Text="{Binding Month}" FontWeight="Bold" MinWidth="80"/>
							<TextBlock Text=":"/>
							<TextBlock Text="{Binding Total}"/>
						</StackPanel>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</StackPanel>
	</Grid>
</Window>
